generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth.js Models ====================

model Contador {
  id            String    @id @default(cuid())
  email         String    @unique
  password_hash String
  nombre_completo String?
  telefono      String?
  emailVerified DateTime?
  imagen        String?
  created_at    DateTime  @default(now())

  // Relaciones Auth.js
  cuentas           Cuenta[]
  sesiones          Sesion[]

  // Relaciones negocio
  clientes          Cliente[]
  configuracion     ConfiguracionContador?
  plantillas        PlantillaMensaje[]
  envios_log        EnvioLog[]
  cargas_calendario CargaCalendario[]

  @@map("contadores")
}

model Cuenta {
  id                String  @id @default(cuid())
  contadorId        String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  contador Contador @relation(fields: [contadorId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("cuentas")
}

model Sesion {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  contadorId   String
  expires      DateTime

  contador Contador @relation(fields: [contadorId], references: [id], onDelete: Cascade)

  @@map("sesiones")
}

model TokenVerificacion {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("tokens_verificacion")
}

// ==================== Configuración ====================

model ConfiguracionContador {
  id              String  @id @default(cuid())
  contador_id     String  @unique
  umbral_urgente_dias  Int @default(5)
  umbral_proximo_dias  Int @default(15)
  umbral_vigilar_dias  Int @default(30)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  contador Contador @relation(fields: [contador_id], references: [id], onDelete: Cascade)

  @@map("configuracion_contador")
}

// ==================== Clientes ====================

model Cliente {
  id                   String    @id @default(cuid())
  contador_id          String
  nombre_completo      String
  cedula               String
  celular_whatsapp     String?
  tipo_ingresos        String    // empleado, independiente, pensionado, mixto, otro
  activo               Boolean   @default(true)
  estado_declaracion   String    @default("pendiente") // pendiente, en_proceso, elaborada
  fecha_completado     DateTime?
  notas                String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  contador Contador @relation(fields: [contador_id], references: [id], onDelete: Cascade)
  envios   EnvioLog[]

  @@unique([contador_id, cedula])
  @@map("clientes")
}

// ==================== Calendario de Vencimientos ====================

model CalendarioVencimiento {
  id                  String   @id @default(cuid())
  anio_gravable       Int
  terminacion_inicio  Int      // 0-99
  terminacion_fin     Int      // 0-99
  fecha_vencimiento   DateTime @db.Date
  origen              String   @default("manual") // manual, excel
  created_by          String?
  created_at          DateTime @default(now())

  @@map("calendario_vencimientos")
}

model CargaCalendario {
  id                  String   @id @default(cuid())
  contador_id         String?
  anio_gravable       Int
  nombre_archivo      String
  filas_importadas    Int
  filas_con_error     Int
  estado              String   @default("procesado") // procesado, con_errores, revertido
  importado_en        DateTime @default(now())

  contador Contador? @relation(fields: [contador_id], references: [id], onDelete: SetNull)

  @@map("cargas_calendario")
}

// ==================== Plantillas y Documentos ====================

model PlantillaMensaje {
  id              String   @id @default(cuid())
  contador_id     String
  nombre          String
  nivel_urgencia  String   @default("cualquiera") // vencido, urgente, proximo, vigilar, tranquilo, cualquiera
  cuerpo_texto    String   @db.Text
  usar_ia         Boolean  @default(false)
  activa          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  contador Contador @relation(fields: [contador_id], references: [id], onDelete: Cascade)

  @@map("plantillas_mensaje")
}

model DocumentoPorPerfil {
  id              String @id @default(cuid())
  tipo_ingresos   String // empleado, independiente, pensionado, mixto
  documento       String
  obligatorio     Boolean @default(true)
  created_at      DateTime @default(now())

  @@unique([tipo_ingresos, documento])
  @@map("documentos_por_perfil")
}

// ==================== Historial de Envíos ====================

model EnvioLog {
  id              String   @id @default(cuid())
  contador_id     String
  cliente_id      String
  plantilla_id    String?
  fecha_marcado   DateTime @default(now())
  mensaje_enviado String   @db.Text
  notas           String?
  created_at      DateTime @default(now())

  contador Contador @relation(fields: [contador_id], references: [id], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@map("envios_log")
}